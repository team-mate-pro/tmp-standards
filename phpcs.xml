<?xml version="1.0"?>
<ruleset name="TMP Standards">
    <description>PSR-12 coding standard for TMP Standards package</description>

    <file>src</file>
    <file>tests</file>

    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PSR12"/>

    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="180"/>
            <property name="absoluteLineLimit" value="200"/>
        </properties>
    </rule>

    <!-- Cache file -->
    <arg name="cache" value=".phpcs-cache"/>
</ruleset>
